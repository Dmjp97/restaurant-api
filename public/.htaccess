<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect to HTTPS in production (Railway handles TLS termination)
    # RewriteCond %{HTTP:X-Forwarded-Proto} =http
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Pass Authorization header through (Apache strips it with Rewrite)
    RewriteCond %{HTTP:Authorization} .+
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Allow actual files and directories to be served directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route everything else through the CI4 front controller
    RewriteRule ^(.*)$ index.php/$1 [L,QSA]
</IfModule>

<IfModule !mod_rewrite.c>
    # If mod_rewrite is not available, show a useful error
    ErrorDocument 404 /index.php
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Deny access to hidden files
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
